@inject IStringLocalizer<SharedResource> Localizer

<EditForm Model="Model" FormName="report-entry-form" OnValidSubmit="HandleSaveRequestedAsync">
    <DataAnnotationsValidator />

    <div class="report-entry-form-card">
        <div class="report-entry-form-header">
            <div>
                <p>@Localizer["ReportEntryFormEyebrow"]</p>
                <h1>@Localizer[Model.Id.HasValue ? "ReportEntryEditTitle" : "ReportEntryCreateTitle"]</h1>
            </div>
        </div>

        <div class="report-entry-main-fields">
            <label>
                <span>@Localizer["ReportEntryDate"] *</span>
                <div class="report-entry-date-control">
                    <button class="report-entry-day-button" type="button" title="@Localizer["ReportEntryPreviousDay"]" aria-label="@Localizer["ReportEntryPreviousDay"]" @onclick="MoveToPreviousDay">
                        <span aria-hidden="true">&lt;</span>
                    </button>
                    <InputDate class="form-control" @bind-Value="Model.Date" @bind-Value:after="FieldChangedAsync" />
                    <button class="report-entry-day-button" type="button" title="@Localizer["ReportEntryNextDay"]" aria-label="@Localizer["ReportEntryNextDay"]" @onclick="MoveToNextDay">
                        <span aria-hidden="true">&gt;</span>
                    </button>
                </div>
            </label>

            <label>
                <span>@Localizer["ReportEntryTitle"] *</span>
                <InputText class="form-control" @bind-Value="Model.Title" @bind-Value:after="FieldChangedAsync" />
                <ValidationMessage For="() => Model.Title" />
            </label>

            <label>
                <span>@Localizer["ReportEntryOrderNumber"]</span>
                <InputText class="form-control" list="report-entry-order-codes" @bind-Value="Model.OrderNumber" @bind-Value:after="OrderNumberChangedAsync" />
                <datalist id="report-entry-order-codes">
                    @foreach (var option in OrderNumberOptions)
                    {
                        <option value="@option.Code">@option.Label</option>
                    }
                </datalist>
                <ValidationMessage For="() => Model.OrderNumber" />
            </label>

            @if (SchoolDaySuggestion?.IsSchoolDay == true)
            {
                <div class="report-entry-school-hint">
                    <span>@Localizer["ReportEntrySchoolDayHint"]</span>
                    <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="ApplySchoolDayTemplateAsync">
                        @Localizer["ReportEntryApplySchoolDay"]
                    </button>
                </div>
            }

            <label>
                <span>@Localizer["ReportEntryDescription"]</span>
                <InputTextArea class="form-control report-entry-description" @bind-Value="Model.Description" @bind-Value:after="FieldChangedAsync" />
                <ValidationMessage For="() => Model.Description" />
            </label>

            <label class="report-entry-check">
                <InputCheckbox @bind-Value="Model.IsVocationalSchoolDay" @bind-Value:after="FieldChangedAsync" />
                <span>@Localizer["ReportEntryVocationalSchoolDay"]</span>
            </label>

            @if (Model.IsVocationalSchoolDay)
            {
                <label>
                    <span>@Localizer["ReportEntrySubject"]</span>
                    <InputText class="form-control" @bind-Value="Model.Subject" @bind-Value:after="FieldChangedAsync" />
                    <ValidationMessage For="() => Model.Subject" />
                </label>
            }

            <div class="report-entry-time-grid">
                <label>
                    <span>@Localizer["ReportEntryStartTime"]</span>
                    <InputSelect class="form-select report-entry-time-input" @bind-Value="Model.StartTime" @bind-Value:after="TimeChanged">
                        @foreach (var time in TimeOptions)
                        {
                            <option value="@time">@time</option>
                        }
                    </InputSelect>
                </label>

                <label>
                    <span>@Localizer["ReportEntryEndTime"]</span>
                    <InputSelect class="form-select report-entry-time-input" @bind-Value="Model.EndTime" @bind-Value:after="TimeChanged">
                        @foreach (var time in TimeOptions)
                        {
                            <option value="@time">@time</option>
                        }
                    </InputSelect>
                </label>
            </div>

            <label>
                <span>@Localizer["ReportEntryNotes"]</span>
                <InputText class="form-control" @bind-Value="Model.Notes" @bind-Value:after="FieldChangedAsync" />
                <ValidationMessage For="() => Model.Notes" />
            </label>
        </div>

        <ValidationSummary />

        <div class="report-entry-actions">
            <button class="btn btn-outline-secondary" type="button" @onclick="HandleDraftRequestedAsync">@Localizer["ReportEntrySaveDraft"]</button>
            <button class="btn btn-primary" type="submit">@Localizer["ReportEntrySave"]</button>
            @if (Model.Id.HasValue)
            {
                <button class="report-entry-delete-link" type="button" @onclick="OnDelete">@Localizer["ReportEntryDelete"]</button>
            }
        </div>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ReportEntryFormModel Model { get; set; } = null!;

    [Parameter]
    public decimal CalculatedHours { get; set; }

    [Parameter]
    public bool RestoredDraft { get; set; }

    [Parameter]
    public SchoolDaySuggestionViewModel? SchoolDaySuggestion { get; set; }

    [Parameter]
    public EventCallback<ReportEntryFormModel> OnFieldChanged { get; set; }

    [Parameter]
    public EventCallback<ReportEntryFormModel> OnDraft { get; set; }

    [Parameter]
    public EventCallback<ReportEntryFormModel> OnSave { get; set; }

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private static readonly IReadOnlyList<string> BaseTimeOptions = CreateTimeOptions();
    private static readonly IReadOnlyList<OrderNumberOption> OrderNumberOptions =
    [
        new("BETRIEB", "Betrieb"),
        new("SCHULE", "Berufsschule"),
        new("URLAUB", "Urlaub"),
        new("KRANK", "Krankheit"),
        new("ÜBERSTUNDEN", "Überstunden"),
        new("SONSTIGES", "Sonstiges")
    ];

    private IReadOnlyList<string> TimeOptions { get; set; } = BaseTimeOptions;

    protected override void OnParametersSet()
    {
        TimeOptions = GetTimeOptions(Model.StartTime, Model.EndTime);
    }

    private Task FieldChangedAsync()
    {
        return OnFieldChanged.InvokeAsync(Model);
    }

    private Task OrderNumberChangedAsync()
    {
        Model.IsOrderNumberOverridden = true;
        return FieldChangedAsync();
    }

    private Task ApplySchoolDayTemplateAsync()
    {
        Model.IsVocationalSchoolDay = true;

        if (SchoolDaySuggestion?.VocationalSchoolCategoryId is int categoryId)
        {
            Model.CategoryId = categoryId;
        }

        if (!Model.IsOrderNumberOverridden)
        {
            Model.OrderNumber = "SCHULE";
        }

        if (string.IsNullOrWhiteSpace(Model.Description) && SchoolDaySuggestion is not null)
        {
            Model.Description = SchoolDaySuggestion.SubjectsText;
        }

        return FieldChangedAsync();
    }

    private void TimeChanged()
    {
        TimeOptions = GetTimeOptions(Model.StartTime, Model.EndTime);
    }

    private Task HandleDraftRequestedAsync()
    {
        return OnDraft.InvokeAsync(Model);
    }

    private Task HandleSaveRequestedAsync()
    {
        return OnSave.InvokeAsync(Model);
    }

    private Task MoveToPreviousDay()
    {
        Model.Date = Model.Date.AddDays(-1);
        return FieldChangedAsync();
    }

    private Task MoveToNextDay()
    {
        Model.Date = Model.Date.AddDays(1);
        return FieldChangedAsync();
    }

    private static IReadOnlyList<string> GetTimeOptions(params string[] selectedTimes)
    {
        var options = BaseTimeOptions
            .Concat(selectedTimes.Where(IsValidTime))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(time => time, StringComparer.Ordinal)
            .ToList();

        return options;
    }

    private static IReadOnlyList<string> CreateTimeOptions()
    {
        return Enumerable.Range(0, 24 * 4)
            .Select(index => TimeSpan.FromMinutes(index * 15).ToString(@"hh\:mm", System.Globalization.CultureInfo.InvariantCulture))
            .ToList();
    }

    private static bool IsValidTime(string time)
    {
        return TimeSpan.TryParse(time, System.Globalization.CultureInfo.InvariantCulture, out var parsed)
            && parsed >= TimeSpan.Zero
            && parsed < TimeSpan.FromDays(1);
    }

    private sealed record OrderNumberOption(string Code, string Label);
}
