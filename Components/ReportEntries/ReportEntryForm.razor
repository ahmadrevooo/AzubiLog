@using System.Globalization
@inject IStringLocalizer<SharedResource> Localizer

<EditForm Model="Model" FormName="report-entry-form" OnValidSubmit="HandleSaveRequestedAsync">
    <DataAnnotationsValidator />

    <div class="report-entry-form-card">
        <div class="report-entry-date-control" aria-label="@Localizer["ReportEntryDate"]">
            <button class="report-entry-day-button" type="button" title="@Localizer["ReportEntryPreviousDay"]" aria-label="@Localizer["ReportEntryPreviousDay"]" @onclick="MoveToPreviousDay">
                <span aria-hidden="true">&lt;</span>
            </button>
            <span class="report-entry-date-text">@FormattedSelectedDate</span>
            <button class="report-entry-today-button" type="button" @onclick="MoveToToday">
                @Localizer["ReportEntryToday"]
            </button>
            <button class="report-entry-day-button" type="button" title="@Localizer["ReportEntryNextDay"]" aria-label="@Localizer["ReportEntryNextDay"]" @onclick="MoveToNextDay">
                <span aria-hidden="true">&gt;</span>
            </button>
        </div>

        <div class="report-entry-form-header">
            <h1>@Localizer[Model.Id.HasValue ? "ReportEntryEditTitle" : "ReportEntryCreateTitle"]</h1>
            <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="OnNewEntry">
                @Localizer["ReportEntryNewEntry"]
            </button>
        </div>

        @if (ShowSchoolDayHint && SchoolDaySubjects.Count > 0)
        {
            <div class="report-entry-school-section">
                <div class="report-entry-school-badge">Berufsschultag</div>
                <div class="report-entry-school-subjects">
                    @for (var i = 0; i < SchoolDaySubjects.Count; i++)
                    {
                        var subject = SchoolDaySubjects[i];
                        var idx = i;
                        <div class="report-entry-subject-row @(subject.Entfall ? "is-entfall" : "")">
                            <div class="report-entry-subject-header">
                                <strong>@subject.Fach</strong>
                                @if (subject.Entfall)
                                {
                                    <span class="report-entry-subject-entfall">Entfall</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(subject.Lehrer))
                                {
                                    <span class="report-entry-subject-teacher">@subject.Lehrer</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(subject.Raum))
                                {
                                    <span class="report-entry-subject-room">@subject.Raum</span>
                                }
                            </div>
                            @if (!subject.Entfall)
                            {
                            <textarea class="form-control report-entry-subject-notes"
                                      placeholder="Was wurde gemacht?"
                                      value="@GetSubjectNote(idx)"
                                      @oninput="@(e => SetSubjectNote(idx, e.Value?.ToString()))"></textarea>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else if (ShowSchoolDayHint)
        {
            <div class="report-entry-school-section">
                <div class="report-entry-school-badge">Berufsschultag</div>
                <span class="report-entry-school-no-subjects">Keine Fächer im Stundenplan eingetragen.</span>
            </div>
        }

        <div class="report-entry-main-fields">
            @if (!ShowSchoolDayHint || AllSubjectsCancelled)
            {
            <section class="report-entry-section">
                <label>
                    <span>@Localizer["ReportEntryTitle"] *</span>
                    <InputText class="form-control" @bind-Value="Model.Title" @bind-Value:after="FieldChangedAsync" />
                    <ValidationMessage For="() => Model.Title" />
                </label>

                <label>
                    <span>@Localizer["ReportEntryDescription"]</span>
                    <InputTextArea class="form-control report-entry-description" @bind-Value="Model.Description" @bind-Value:after="FieldChangedAsync" oninput="this.style.height='auto';this.style.height=this.scrollHeight+'px'" />
                    <ValidationMessage For="() => Model.Description" />
                </label>
            </section>

            <section class="report-entry-section">
                <div class="report-entry-time-grid">
                    <label>
                        <span>@Localizer["ReportEntryStartTime"]</span>
                        <div class="report-entry-time-control">
                            <input class="form-control report-entry-time-input" type="text" inputmode="numeric" maxlength="5" placeholder="08:00" value="@Model.StartTime" @oninput="HandleStartTimeInputAsync" />
                            <div class="report-entry-time-stepper">
                                <button type="button" title="Startzeit erhöhen" aria-label="Startzeit erhöhen" @onclick="IncreaseStartTimeAsync">+</button>
                                <button type="button" title="Startzeit verringern" aria-label="Startzeit verringern" @onclick="DecreaseStartTimeAsync">-</button>
                            </div>
                        </div>
                        @if (!IsStartTimeValid)
                        {
                            <span class="report-entry-field-hint">Bitte im Format HH:mm eingeben.</span>
                        }
                    </label>

                    <label>
                        <span>@Localizer["ReportEntryEndTime"]</span>
                        <div class="report-entry-time-control">
                            <input class="form-control report-entry-time-input" type="text" inputmode="numeric" maxlength="5" placeholder="16:00" value="@Model.EndTime" @oninput="HandleEndTimeInputAsync" />
                            <div class="report-entry-time-stepper">
                                <button type="button" title="Endzeit erhöhen" aria-label="Endzeit erhöhen" @onclick="IncreaseEndTimeAsync">+</button>
                                <button type="button" title="Endzeit verringern" aria-label="Endzeit verringern" @onclick="DecreaseEndTimeAsync">-</button>
                            </div>
                        </div>
                        @if (!IsEndTimeValid)
                        {
                            <span class="report-entry-field-hint">Bitte im Format HH:mm eingeben.</span>
                        }
                        else if (!HasChronologicalTimes)
                        {
                            <span class="report-entry-field-hint">Endzeit muss nach Startzeit liegen.</span>
                        }
                    </label>

                    <div class="report-entry-duration">
                        <span>@Localizer["ReportEntryCalculatedHours"]: @CalculatedHours.ToString("0.##") h</span>
                    </div>
                </div>
            </section>
            }

            <section class="report-entry-section">
                <div class="report-entry-info-grid">
                    <label>
                        <span>@Localizer["ReportEntryCategory"] *</span>
                        <div class="report-entry-category-control">
                            <InputSelect class="form-select" TValue="int?" @bind-Value="Model.CategoryId" @bind-Value:after="CategoryChangedAsync">
                                <option value="">@Localizer["ReportEntrySelectCategory"]</option>
                                @foreach (var category in Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </InputSelect>
                            <button class="report-entry-icon-button" type="button" title="@Localizer["ReportEntryAddCategory"]" @onclick="ToggleCategoryCreator">
                                +
                            </button>
                        </div>
                    </label>

                    <label>
                        <span>@Localizer["ReportEntryTrainer"]</span>
                        <InputSelect class="form-select" TValue="int?" @bind-Value="Model.TrainerId" @bind-Value:after="FieldChangedAsync">
                            <option value="">@Localizer["ReportEntryNoTrainer"]</option>
                            @foreach (var trainer in Trainers)
                            {
                                <option value="@trainer.Id">@trainer.Name</option>
                            }
                        </InputSelect>
                    </label>
                </div>

                @if (IsCategoryCreatorOpen)
                {
                    <div class="report-entry-category-popover">
                        <InputText class="form-control" @bind-Value="NewCategoryName" placeholder="@Localizer["ReportEntryNewCategory"]" />
                        <button class="btn btn-primary btn-sm" type="button" @onclick="CreateCategoryAsync">
                            @Localizer["ReportEntryAddCategory"]
                        </button>
                    </div>
                }



                @if (IsNoteOpen || !string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <label>
                        <span>@Localizer["ReportEntryNotes"]</span>
                        <InputText class="form-control" @bind-Value="Model.Notes" @bind-Value:after="FieldChangedAsync" />
                        <ValidationMessage For="() => Model.Notes" />
                    </label>

                    @if (string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <button class="report-entry-note-toggle" type="button" @onclick="HideNote">
                            Notiz ausblenden
                        </button>
                    }
                }
                else
                {
                    <button class="report-entry-note-toggle" type="button" @onclick="ShowNote">
                        + Notiz hinzufügen
                    </button>
                }
            </section>
        </div>

        <ValidationSummary />

        <div class="report-entry-actions">
            <button class="btn btn-outline-secondary" type="button" @onclick="HandleDraftRequestedAsync">@Localizer["ReportEntrySaveDraft"]</button>
            <button class="btn btn-primary" type="submit">@Localizer["ReportEntrySave"]</button>
            @if (Model.Id.HasValue)
            {
                <button class="report-entry-delete-link" type="button" @onclick="OnDelete">@Localizer["ReportEntryDelete"]</button>
            }
        </div>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ReportEntryFormModel Model { get; set; } = null!;

    [Parameter]
    public decimal CalculatedHours { get; set; }

    [Parameter]
    public bool RestoredDraft { get; set; }

    [Parameter]
    public IReadOnlyList<ReportEntryOption> Categories { get; set; } = [];

    [Parameter]
    public IReadOnlyList<ReportEntryOption> Trainers { get; set; } = [];

    [Parameter]
    public EventCallback<ReportEntryFormModel> OnFieldChanged { get; set; }

    [Parameter]
    public EventCallback<DateTime> OnDateChanged { get; set; }

    [Parameter]
    public EventCallback<string> OnCreateCategory { get; set; }

    [Parameter]
    public bool ShowSchoolDayHint { get; set; }

    [Parameter]
    public IReadOnlyList<SchoolSubjectEntry> SchoolDaySubjects { get; set; } = [];

    [Parameter]
    public EventCallback OnApplySchoolDay { get; set; }

    [Parameter]
    public EventCallback OnNewEntry { get; set; }

    [Parameter]
    public EventCallback<ReportEntryFormModel> OnDraft { get; set; }

    [Parameter]
    public EventCallback<ReportEntryFormModel> OnSave { get; set; }

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private string NewCategoryName { get; set; } = string.Empty;
    private bool IsCategoryCreatorOpen { get; set; }
    private bool IsNoteOpen { get; set; }
    private ReportEntryFormModel? PreviousModel { get; set; }
    private List<string> SubjectNotes { get; set; } = new();

    private string FormattedSelectedDate
    {
        get
        {
            return Model.Date.ToString("dddd, dd.MM.yyyy", GermanCulture);
        }
    }

    private static readonly CultureInfo GermanCulture = CultureInfo.GetCultureInfo("de-DE");

    private bool IsStartTimeValid => TryParseTime(Model.StartTime, out _);

    private bool IsEndTimeValid => TryParseTime(Model.EndTime, out _);

    private bool HasChronologicalTimes
    {
        get
        {
            if (!TryParseTime(Model.StartTime, out var start) || !TryParseTime(Model.EndTime, out var end))
            {
                return true;
            }

            return end > start;
        }
    }

    private bool HasValidTimeRange => IsStartTimeValid && IsEndTimeValid && HasChronologicalTimes;

    private bool AllSubjectsCancelled => SchoolDaySubjects.Count > 0 && SchoolDaySubjects.All(s => s.Entfall);

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(PreviousModel, Model))
        {
            IsNoteOpen = !string.IsNullOrWhiteSpace(Model.Notes);
            PreviousModel = Model;

            if (ShowSchoolDayHint)
            {
                AutoSetSchoolCategory();

                if (!AllSubjectsCancelled)
                {
                    if (string.IsNullOrWhiteSpace(Model.Title))
                    {
                        Model.Title = "Berufsschultag";
                    }

                    if (string.IsNullOrWhiteSpace(Model.StartTime))
                    {
                        Model.StartTime = "08:00";
                    }

                    if (string.IsNullOrWhiteSpace(Model.EndTime))
                    {
                        Model.EndTime = "16:00";
                    }
                }

                if (SchoolDaySubjects.Count > 0)
                {
                    InitSubjectNotes();
                }
            }

            return;
        }

        if (!IsNoteOpen && !string.IsNullOrWhiteSpace(Model.Notes))
        {
            IsNoteOpen = true;
        }
    }

    private void AutoSetSchoolCategory()
    {
        var schoolCategory = Categories.FirstOrDefault(c =>
            c.Name.Contains("Berufsschule", StringComparison.OrdinalIgnoreCase)
            || c.Name.Contains("Schule", StringComparison.OrdinalIgnoreCase));

        if (schoolCategory is not null)
        {
            Model.CategoryId = schoolCategory.Id;
        }
    }

    private void InitSubjectNotes()
    {
        while (SubjectNotes.Count < SchoolDaySubjects.Count)
        {
            SubjectNotes.Add(string.Empty);
        }
    }

    private string GetSubjectNote(int index)
    {
        return index < SubjectNotes.Count ? SubjectNotes[index] : string.Empty;
    }

    private void SetSubjectNote(int index, string? value)
    {
        while (SubjectNotes.Count <= index)
        {
            SubjectNotes.Add(string.Empty);
        }
        SubjectNotes[index] = value ?? string.Empty;
        BuildDescriptionFromSubjects();
    }

    private void BuildDescriptionFromSubjects()
    {
        var parts = new List<string>();
        for (var i = 0; i < SchoolDaySubjects.Count && i < SubjectNotes.Count; i++)
        {
            var subject = SchoolDaySubjects[i];
            var note = SubjectNotes[i];
            if (!string.IsNullOrWhiteSpace(note))
            {
                parts.Add($"{subject.Fach}: {note.Trim()}");
            }
            else
            {
                parts.Add($"{subject.Fach}: -");
            }
        }

        Model.Description = string.Join(Environment.NewLine, parts);
    }

    private Task FieldChangedAsync()
    {
        return OnFieldChanged.InvokeAsync(Model);
    }

    private Task HandleStartTimeInputAsync(ChangeEventArgs args)
    {
        Model.StartTime = args.Value?.ToString() ?? string.Empty;
        return FieldChangedAsync();
    }

    private Task HandleEndTimeInputAsync(ChangeEventArgs args)
    {
        Model.EndTime = args.Value?.ToString() ?? string.Empty;
        return FieldChangedAsync();
    }

    private Task IncreaseStartTimeAsync()
    {
        Model.StartTime = StepTime(Model.StartTime, "08:00", 15);
        return FieldChangedAsync();
    }

    private Task DecreaseStartTimeAsync()
    {
        Model.StartTime = StepTime(Model.StartTime, "08:00", -15);
        return FieldChangedAsync();
    }

    private Task IncreaseEndTimeAsync()
    {
        Model.EndTime = StepTime(Model.EndTime, "16:00", 15);
        return FieldChangedAsync();
    }

    private Task DecreaseEndTimeAsync()
    {
        Model.EndTime = StepTime(Model.EndTime, "16:00", -15);
        return FieldChangedAsync();
    }

    private Task CategoryChangedAsync()
    {
        return FieldChangedAsync();
    }

    private void ToggleCategoryCreator()
    {
        IsCategoryCreatorOpen = !IsCategoryCreatorOpen;
    }

    private async Task CreateCategoryAsync()
    {
        if (string.IsNullOrWhiteSpace(NewCategoryName))
        {
            return;
        }

        await OnCreateCategory.InvokeAsync(NewCategoryName);
        NewCategoryName = string.Empty;
        IsCategoryCreatorOpen = false;
    }

    private Task HandleDraftRequestedAsync()
    {
        return OnDraft.InvokeAsync(Model);
    }

    private Task HandleSaveRequestedAsync()
    {
        if (ShowSchoolDayHint)
        {
            if (string.IsNullOrWhiteSpace(Model.Title))
            {
                Model.Title = "Berufsschultag";
            }

            if (string.IsNullOrWhiteSpace(Model.StartTime))
            {
                Model.StartTime = "08:00";
            }

            if (string.IsNullOrWhiteSpace(Model.EndTime))
            {
                Model.EndTime = "15:00";
            }
        }
        else if (!HasValidTimeRange)
        {
            return Task.CompletedTask;
        }

        return OnSave.InvokeAsync(Model);
    }

    private Task MoveToPreviousDay()
    {
        return OnDateChanged.InvokeAsync(Model.Date.AddDays(-1));
    }

    private Task MoveToNextDay()
    {
        return OnDateChanged.InvokeAsync(Model.Date.AddDays(1));
    }

    private Task MoveToToday()
    {
        return OnDateChanged.InvokeAsync(DateTime.Today);
    }

    private void ShowNote()
    {
        IsNoteOpen = true;
    }

    private void HideNote()
    {
        if (string.IsNullOrWhiteSpace(Model.Notes))
        {
            IsNoteOpen = false;
        }
    }

    private static string GetDefaultOrderNumber(string? categoryName)
    {
        var normalizedName = (categoryName ?? string.Empty).Trim().ToLowerInvariant();

        if (normalizedName.Contains("berufsschule", StringComparison.Ordinal))
        {
            return "SCHULE";
        }

        if (normalizedName.Contains("urlaub", StringComparison.Ordinal))
        {
            return "URLAUB";
        }

        if (normalizedName.Contains("krank", StringComparison.Ordinal))
        {
            return "KRANK";
        }

        if (normalizedName.Contains("überstunden", StringComparison.Ordinal)
            || normalizedName.Contains("overtime", StringComparison.Ordinal))
        {
            return "ÜBERSTUNDEN";
        }

        return "BETRIEB";
    }

    private static bool TryParseTime(string value, out TimeSpan time)
    {
        return TimeSpan.TryParseExact(value, "hh\\:mm", CultureInfo.InvariantCulture, out time)
            && time < TimeSpan.FromDays(1);
    }

    private static string StepTime(string value, string fallback, int minutes)
    {
        if (!TryParseTime(value, out var time))
        {
            TryParseTime(fallback, out time);
        }

        var stepped = time.Add(TimeSpan.FromMinutes(minutes));
        if (stepped < TimeSpan.Zero)
        {
            stepped = TimeSpan.Zero;
        }
        else if (stepped >= TimeSpan.FromDays(1))
        {
            stepped = TimeSpan.FromDays(1).Subtract(TimeSpan.FromMinutes(1));
        }

        return stepped.ToString("hh\\:mm", CultureInfo.InvariantCulture);
    }

}
