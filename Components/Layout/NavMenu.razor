@inject IApplicationNavigationService Navigation
@inject IStringLocalizer<SharedResource> Localizer
@inject ICurrentUserService CurrentUserService

<div class="sidebar-brand">
    <a class="navbar-brand" href="">
        <img src="images/logo.png" alt="AzubiLog" class="navbar-logo" />
        <span class="brand-text">@Localizer["AppName"]</span>
    </a>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-section-label">MENU</div>
        @foreach (var item in Navigation.GetMainNavigation())
        {
            <div class="nav-item">
                @if (item.IsEnabled)
                {
                    <NavLink class="nav-link" href="@item.Href" Match="@GetMatch(item)">
                        <span class="nav-icon bi @item.IconCssClass" aria-hidden="true"></span>
                        <span class="nav-label">@Localizer[item.ResourceKey]</span>
                    </NavLink>
                }
                else
                {
                    <span class="nav-link nav-link-disabled" title="@Localizer["ComingSoon"]">
                        <span class="nav-icon bi @item.IconCssClass" aria-hidden="true"></span>
                        <span class="nav-label">@Localizer[item.ResourceKey]</span>
                    </span>
                }
            </div>
        }
        @if (IsKlassensprecher)
        {
            <div class="nav-item">
                <NavLink class="nav-link" href="timetable" Match="NavLinkMatch.Prefix">
                    <span class="nav-icon bi bi-calendar-week-nav-menu" aria-hidden="true"></span>
                    <span class="nav-label">@Localizer["TimetableNavItem"]</span>
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="class-members" Match="NavLinkMatch.Prefix">
                    <span class="nav-icon bi bi-people-fill-nav-menu" aria-hidden="true"></span>
                    <span class="nav-label">@Localizer["ClassMembersNavItem"]</span>
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    private bool IsKlassensprecher { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = await CurrentUserService.GetRequiredUserAsync();
            IsKlassensprecher = user.Role == AzubiLog.Models.UserRole.Klassensprecher;
        }
        catch
        {
            IsKlassensprecher = false;
        }
    }

    private static NavLinkMatch GetMatch(NavigationItem item)
    {
        return string.IsNullOrWhiteSpace(item.Href)
            ? NavLinkMatch.All
            : NavLinkMatch.Prefix;
    }
}
