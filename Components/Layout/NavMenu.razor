@inject IApplicationNavigationService Navigation
@inject IStringLocalizer<SharedResource> Localizer
@inject IJSRuntime JsRuntime

<header class="app-navbar">
    <div class="app-navbar__inner">
        <a class="app-navbar__brand" href="">
            <img src="/images/logo.png" alt="@Localizer["AppName"]" class="app-navbar__logo" />
        </a>

        <nav class="app-navbar__desktop-nav" aria-label="@Localizer["AppName"]">
            @foreach (var item in Navigation.GetMainNavigation().Take(4))
            {
                @if (item.IsEnabled)
                {
                    <NavLink class="app-navbar__tab" href="@item.Href" Match="@GetMatch(item)">
                        @Localizer[item.ResourceKey]
                    </NavLink>
                }
            }
            <div class="app-navbar__more" @onfocusout="CloseMoreAsync">
                <button class="app-navbar__more-btn" type="button" @onclick="ToggleMoreAsync">
                    Mehr <span class="app-navbar__more-arrow">&#9662;</span>
                </button>
                <div class="app-navbar__more-dropdown @(IsMoreOpen ? "is-open" : null)">
                    @foreach (var item in Navigation.GetMainNavigation().Skip(4))
                    {
                        @if (item.IsEnabled)
                        {
                            <NavLink class="app-navbar__more-item" href="@item.Href" Match="@GetMatch(item)" @onclick="CloseMoreAsync">
                                @Localizer[item.ResourceKey]
                            </NavLink>
                        }
                    }
                </div>
            </div>
        </nav>

        <div class="app-navbar__actions">
            <AuthorizeView>
                <Authorized>
                    <a class="app-navbar__account-link" href="/account/logout">@Localizer["AccountLogoutAction"]</a>
                </Authorized>
                <NotAuthorized>
                    <a class="app-navbar__account-link" href="/account/login">@Localizer["AccountLoginAction"]</a>
                </NotAuthorized>
            </AuthorizeView>

            <button class="app-navbar__toggle"
                    type="button"
                    aria-label="Menu"
                    aria-expanded="@IsMenuOpen.ToString().ToLowerInvariant()"
                    @onclick="ToggleMenuAsync">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>

    <div class="app-navbar__mobile-panel @(IsMenuOpen ? "is-open" : null)">
        <div class="app-navbar__mobile-backdrop" @onclick="CloseMenuAsync"></div>
        <nav class="app-navbar__mobile-menu" aria-label="@Localizer["AppName"]">
            @foreach (var item in Navigation.GetMainNavigation())
            {
                @if (item.IsEnabled)
                {
                    <NavLink class="app-navbar__mobile-link" href="@item.Href" Match="@GetMatch(item)" @onclick="CloseMenuAsync">
                        @Localizer[item.ResourceKey]
                    </NavLink>
                }
            }
            <div class="app-navbar__mobile-meta">
                <AuthorizeView>
                    <Authorized>
                        <a class="app-navbar__account-link app-navbar__account-link--mobile" href="/account/logout" @onclick="CloseMenuAsync">@Localizer["AccountLogoutAction"]</a>
                    </Authorized>
                    <NotAuthorized>
                        <a class="app-navbar__account-link app-navbar__account-link--mobile" href="/account/login" @onclick="CloseMenuAsync">@Localizer["AccountLoginAction"]</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>
    </div>
</header>

@code {
    private bool IsMenuOpen { get; set; }
    private bool IsMoreOpen { get; set; }
    private string CurrentTheme { get; set; } = "light";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        CurrentTheme = await JsRuntime.InvokeAsync<string>("azubiLogPreferences.getTheme");
        StateHasChanged();
    }

    private Task ToggleMenuAsync()
    {
        IsMenuOpen = !IsMenuOpen;
        return Task.CompletedTask;
    }

    private Task CloseMenuAsync()
    {
        IsMenuOpen = false;
        return Task.CompletedTask;
    }

    private Task ToggleMoreAsync()
    {
        IsMoreOpen = !IsMoreOpen;
        return Task.CompletedTask;
    }

    private Task CloseMoreAsync()
    {
        IsMoreOpen = false;
        return Task.CompletedTask;
    }

    private static NavLinkMatch GetMatch(NavigationItem item)
    {
        return string.IsNullOrWhiteSpace(item.Href)
            ? NavLinkMatch.All
            : NavLinkMatch.Prefix;
    }
}
