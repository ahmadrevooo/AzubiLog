@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> Localizer
@inject IJSRuntime JsRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IApplicationNavigationService Navigation
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<div class="page" @onkeydown="HandleShellKeyDown">
    @if (IsProfileMenuOpen || IsMobileMenuOpen || IsMoreMenuOpen)
    {
        <button class="app-shell-scrim" type="button" aria-label="Menü schließen" @onclick="CloseMenus"></button>
    }

    <header class="app-header">
        <div class="app-header-inner">
            <a class="app-wordmark" href="" @onclick="CloseMenus">@Localizer["AppName"]</a>

            <nav class="app-primary-nav" aria-label="Hauptnavigation">
                @foreach (var item in PrimaryNavigation)
                {
                    <NavLink class="app-nav-link" href="@item.Href" Match="@GetMatch(item)">
                        @GetNavigationText(item)
                    </NavLink>
                }

                <div class="app-more-nav">
                    <button class="app-nav-link app-more-button @(IsSecondaryPageActive ? "active" : null)" type="button" aria-haspopup="menu" aria-expanded="@IsMoreMenuOpen" @onclick="ToggleMoreMenu">
                        <span>Mehr</span>
                        <span aria-hidden="true">▾</span>
                    </button>

                    @if (IsMoreMenuOpen)
                    {
                        <div class="app-more-menu" role="menu">
                            @foreach (var item in SecondaryNavigation)
                            {
                                <NavLink class="app-more-menu-link" href="@item.Href" Match="@GetMatch(item)" @onclick="CloseMenus">
                                    @Localizer[item.ResourceKey]
                                </NavLink>
                            }
                        </div>
                    }
                </div>
            </nav>

            <div class="app-header-actions">
                <button class="app-mobile-menu-button" type="button" aria-label="Navigation öffnen" aria-expanded="@IsMobileMenuOpen" @onclick="ToggleMobileMenu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <AuthorizeView>
                    <Authorized>
                        <button class="app-theme-switch" type="button" role="switch" aria-checked="@(CurrentTheme == "dark")" aria-label="Darstellung wechseln" @onclick="ToggleThemeAsync">
                            <span class="app-theme-icon" aria-hidden="true">☀</span>
                            <span class="app-theme-track">
                                <span class="app-theme-thumb"></span>
                            </span>
                            <span class="app-theme-icon" aria-hidden="true">☾</span>
                        </button>

                        <div class="app-profile">
                            <button class="app-avatar-button" type="button" aria-label="Profilmenü öffnen" aria-expanded="@IsProfileMenuOpen" @onclick="ToggleProfileMenu">
                                <span class="app-avatar-initials">@UserInitials</span>
                                <span class="app-avatar-arrow" aria-hidden="true">▾</span>
                            </button>

                            @if (IsProfileMenuOpen)
                            {
                                <div class="app-profile-menu" role="menu">
                                    <div class="app-profile-identity">
                                        <strong>@UserDisplayName</strong>
                                        <span>@UserEmail</span>
                                    </div>
                                    <a href="/settings" role="menuitem" @onclick="CloseMenus">Profil</a>
                                    <a href="/settings" role="menuitem" @onclick="CloseMenus">Einstellungen</a>
                                    <a href="/account/logout" role="menuitem">@Localizer["AccountLogoutAction"]</a>
                                </div>
                            }
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a class="app-login-link" href="/account/login">@Localizer["AccountLoginAction"]</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        @if (IsMobileMenuOpen)
        {
            <nav class="app-mobile-nav" aria-label="Mobile Navigation">
                @foreach (var item in PrimaryNavigation)
                {
                    <NavLink class="app-mobile-nav-link" href="@item.Href" Match="@GetMatch(item)" @onclick="CloseMenus">
                        @GetNavigationText(item)
                    </NavLink>
                }

                <div class="app-mobile-nav-section">Mehr</div>
                @foreach (var item in SecondaryNavigation)
                {
                    <NavLink class="app-mobile-nav-link" href="@item.Href" Match="@GetMatch(item)" @onclick="CloseMenus">
                        @Localizer[item.ResourceKey]
                    </NavLink>
                }
            </nav>
        }
    </header>

    <main>
        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Localizer["ErrorMessage"]
    <a href="." class="reload">@Localizer["Reload"]</a>
    <span class="dismiss">x</span>
</div>

@code {
    private static readonly HashSet<string> PrimaryNavigationKeys = new(StringComparer.Ordinal)
    {
        "NavDashboard",
        "NavNewEntry",
        "NavWeeklyReports",
        "NavTodos"
    };

    private string CurrentTheme { get; set; } = "light";
    private string UserDisplayName { get; set; } = "AzubiLog";
    private string UserEmail { get; set; } = string.Empty;
    private string UserInitials { get; set; } = "AL";
    private bool IsProfileMenuOpen { get; set; }
    private bool IsMobileMenuOpen { get; set; }
    private bool IsMoreMenuOpen { get; set; }

    private IEnumerable<NavigationItem> PrimaryNavigation =>
        Navigation.GetMainNavigation().Where(item => item.IsEnabled && PrimaryNavigationKeys.Contains(item.ResourceKey));

    private IEnumerable<NavigationItem> SecondaryNavigation =>
        Navigation.GetMainNavigation().Where(item => !string.IsNullOrWhiteSpace(item.Href)
            && (!PrimaryNavigationKeys.Contains(item.ResourceKey) || item.ResourceKey == "NavWeeklyReports"));

    private bool IsSecondaryPageActive =>
        SecondaryNavigation.Any(item => IsCurrentPath(item.Href)
            && (!PrimaryNavigationKeys.Contains(item.ResourceKey) || item.ResourceKey == "NavWeeklyReports"));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        CurrentTheme = await JsRuntime.InvokeAsync<string>("azubiLogPreferences.getTheme");
        await LoadUserAsync();
        StateHasChanged();
    }

    private async Task HandleThemeChangedAsync(ChangeEventArgs args)
    {
        CurrentTheme = args.Value?.ToString() == "dark" ? "dark" : "light";
        await JsRuntime.InvokeVoidAsync("azubiLogPreferences.setTheme", CurrentTheme);
        IsProfileMenuOpen = false;
    }

    private async Task ToggleThemeAsync()
    {
        CurrentTheme = CurrentTheme == "dark" ? "light" : "dark";
        await JsRuntime.InvokeVoidAsync("azubiLogPreferences.setTheme", CurrentTheme);
    }

    private async Task LoadUserAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = state.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            return;
        }

        var applicationUser = await UserManager.GetUserAsync(user);
        UserEmail = applicationUser?.Email
            ?? user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.Identity.Name
            ?? string.Empty;

        var name = string.Join(" ", new[] { applicationUser?.FirstName, applicationUser?.LastName }.Where(value => !string.IsNullOrWhiteSpace(value)));
        UserDisplayName = string.IsNullOrWhiteSpace(name) ? UserEmail : name;
        UserInitials = GetInitials(UserDisplayName, UserEmail);
    }

    private void ToggleProfileMenu()
    {
        IsProfileMenuOpen = !IsProfileMenuOpen;
        IsMobileMenuOpen = false;
        IsMoreMenuOpen = false;
    }

    private void ToggleMoreMenu()
    {
        IsMoreMenuOpen = !IsMoreMenuOpen;
        IsMobileMenuOpen = false;
        IsProfileMenuOpen = false;
    }

    private void ToggleMobileMenu()
    {
        IsMobileMenuOpen = !IsMobileMenuOpen;
        IsProfileMenuOpen = false;
        IsMoreMenuOpen = false;
    }

    private void CloseMenus()
    {
        IsProfileMenuOpen = false;
        IsMobileMenuOpen = false;
        IsMoreMenuOpen = false;
    }

    private void HandleShellKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            CloseMenus();
        }
    }

    private static NavLinkMatch GetMatch(NavigationItem item)
    {
        if (string.Equals(item.Href, "weekly-reports", StringComparison.Ordinal))
        {
            return NavLinkMatch.All;
        }

        return string.IsNullOrWhiteSpace(item.Href)
            ? NavLinkMatch.All
            : NavLinkMatch.Prefix;
    }

    private string GetNavigationText(NavigationItem item)
    {
        return item.ResourceKey switch
        {
            "NavNewEntry" => "Einträge",
            "NavWeeklyReports" => "Wochenübersicht",
            "NavTodos" => "To-dos",
            _ => Localizer[item.ResourceKey]
        };
    }

    private bool IsCurrentPath(string href)
    {
        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        var itemPath = href.Trim('/').TrimEnd('/');

        return string.Equals(currentPath, itemPath, StringComparison.OrdinalIgnoreCase);
    }

    private static string GetInitials(string displayName, string email)
    {
        var source = string.IsNullOrWhiteSpace(displayName) ? email : displayName;
        var parts = source.Split([' ', '.', '@', '-', '_'], StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
        {
            return "AL";
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }
}
