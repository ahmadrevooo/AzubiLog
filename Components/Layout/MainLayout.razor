@inherits LayoutComponentBase
@inject IStringLocalizer<SharedResource> Localizer

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="app-shell-status">@Localizer["TopBarStatus"]</span>
            <span class="app-shell-divider" aria-hidden="true"></span>
            <span>@Localizer["LanguageGerman"]</span>
            <span>@Localizer["ThemeLight"]</span>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Localizer["ErrorMessage"]
    <a href="." class="reload">@Localizer["Reload"]</a>
    <span class="dismiss">x</span>
</div>
