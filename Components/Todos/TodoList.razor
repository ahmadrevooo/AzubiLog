@inject IStringLocalizer<SharedResource> Localizer

<section class="todo-list-panel">
    <header>
        <div class="todo-list-heading">
            <span class="todo-list-heading-icon" aria-hidden="true"></span>
            <h2>@Localizer[TitleKey]</h2>
        </div>
        <span class="todo-list-count">@Items.Count</span>
    </header>

    @if (Items.Count == 0)
    {
        <div class="todo-list-empty">
            <span class="todo-list-empty-icon" aria-hidden="true"></span>
            <strong>@Localizer[EmptyTextKey]</strong>
            <span>@GetEmptyStateHint()</span>
        </div>
    }
    else
    {
        <div class="todo-list">
            @foreach (var todo in Items)
            {
                <article class="todo-list-item @(todo.IsCompleted ? "is-completed" : null)">
                    <div class="todo-list-check">
                        @if (ShowCompleteAction && !todo.IsCompleted)
                        {
                            <button type="button" aria-label="@Localizer["TodoComplete"]" @onclick="() => Complete.InvokeAsync(todo.Id)"></button>
                        }
                        else
                        {
                            <span aria-hidden="true"></span>
                        }
                    </div>
                    <div class="todo-list-item-content">
                        <strong>@todo.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(todo.Description))
                        {
                            <p>@todo.Description</p>
                        }
                        <span class="todo-list-due-date">
                            @if (todo.DueDate.HasValue)
                            {
                                @Localizer["TodoDue", todo.DueDate.Value.ToString("d")]
                            }
                            else
                            {
                                @Localizer["TodoNoDueDate"]
                            }
                        </span>
                    </div>
                    <div class="todo-list-actions">
                        <details>
                            <summary aria-label="Aufgabenmenü">...</summary>
                            <button type="button" @onclick="() => Delete.InvokeAsync(todo.Id)">
                                @Localizer["TodoDelete"]
                            </button>
                        </details>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public string TitleKey { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string EmptyTextKey { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<TodoItemViewModel> Items { get; set; } = [];

    [Parameter]
    public bool ShowCompleteAction { get; set; }

    [Parameter]
    public EventCallback<int> Complete { get; set; }

    [Parameter]
    public EventCallback<int> Delete { get; set; }

    private string GetEmptyStateHint()
    {
        return ShowCompleteAction
            ? "Erstelle eine neue Aufgabe, um loszulegen."
            : "Erledigte Aufgaben erscheinen hier.";
    }
}
