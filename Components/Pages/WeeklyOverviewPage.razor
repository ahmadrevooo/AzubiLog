@page "/weekly-reports"
@attribute [Authorize(Policy = "ConfirmedEmail")]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["WeeklyOverviewPageTitle"]</PageTitle>

@if (Overview is null)
{
    <div class="weekly-overview-page-loading">@Localizer["WeeklyOverviewLoading"]</div>
}
else
{
    <div class="weekly-overview-page">
        <header class="weekly-overview-page-header">
            <div>
                <p>@Localizer["WeeklyOverviewEyebrow"]</p>
                <h1>@Localizer["WeeklyOverviewPageTitle"]</h1>
                <span>@Localizer["WeeklyOverviewPageIntro"]</span>
            </div>
            <div class="weekly-overview-page-actions">
                <section class="weekly-overview-navigation" aria-label="@Localizer["WeeklyOverviewNavigation"]">
                    <button class="weekly-overview-nav-button" type="button" title="@Localizer["WeeklyOverviewPreviousWeek"]" aria-label="@Localizer["WeeklyOverviewPreviousWeek"]" @onclick="GoToPreviousWeek">
                        &lt;
                    </button>
                    <label class="weekly-overview-date-picker">
                        <span class="visually-hidden">@Localizer["WeeklyOverviewJumpToWeek"]</span>
                        <input class="form-control" type="date" value="@SelectedDateString" @onchange="HandleDateChangedAsync" />
                    </label>
                    <button class="weekly-overview-nav-button" type="button" title="@Localizer["WeeklyOverviewNextWeek"]" aria-label="@Localizer["WeeklyOverviewNextWeek"]" @onclick="GoToNextWeek">
                        &gt;
                    </button>
                </section>
            </div>
        </header>

        <WeeklyOverview Overview="Overview" />
    </div>
    <div>
        <a class="btn btn-outline-secondary" href="@ExportHref" download data-enhance-nav="false">@Localizer["DashboardExportPdf"]</a>
    </div>
}
