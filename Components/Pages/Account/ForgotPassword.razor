@page "/account/forgot-password"
@attribute [AllowAnonymous]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["AccountForgotPasswordTitle"]</PageTitle>

<section class="account-page">
    <div class="account-card">
        <div class="account-logo">
            <img src="images/logo.png" alt="AzubiLog" />
        </div>
        <h1>@Localizer["AccountForgotPasswordTitle"]</h1>
        <p>@Localizer["AccountForgotPasswordIntro"]</p>

        @if (Sent)
        {
            <div class="account-status">@Localizer["AccountResetLinkSent"]</div>
        }

        <form method="post" action="/account/forgot-password/submit" class="account-form">
            <label>
                <span>@Localizer["AccountEmail"]</span>
                <input class="form-control" type="email" name="email" autocomplete="email" required />
            </label>
            <button class="btn btn-primary" type="submit">@Localizer["AccountSendResetLink"]</button>
        </form>

        <div class="account-links">
            <a href="/account/login">@Localizer["AccountBackToLogin"]</a>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "sent")]
    private bool Sent { get; set; }
}
