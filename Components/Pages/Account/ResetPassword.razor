@page "/account/reset-password"
@attribute [AllowAnonymous]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["AccountResetPasswordTitle"]</PageTitle>

<section class="account-page">
    <div class="account-card">
        <p class="account-eyebrow">@Localizer["AppName"]</p>
        <h1>@Localizer["AccountResetPasswordTitle"]</h1>
        <p>@Localizer["AccountResetPasswordIntro"]</p>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="account-status account-status-error">@Localizer["AccountResetPasswordFailed"]</div>
        }

        <form method="post" action="/account/reset-password/submit" class="account-form">
            <input type="hidden" name="email" value="@Email" />
            <input type="hidden" name="code" value="@Code" />
            <label>
                <span>@Localizer["AccountPassword"]</span>
                <input class="form-control" type="password" name="password" autocomplete="new-password" required />
            </label>
            <label>
                <span>@Localizer["AccountConfirmPassword"]</span>
                <input class="form-control" type="password" name="confirmPassword" autocomplete="new-password" required />
            </label>
            <button class="btn btn-primary" type="submit">@Localizer["AccountResetPasswordAction"]</button>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "email")]
    private string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "code")]
    private string? Code { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }
}
