@page "/account/register"
@attribute [AllowAnonymous]
@inject IStringLocalizer<SharedResource> Localizer
@using System.Text
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>@Localizer["AccountRegisterTitle"]</PageTitle>

<section class="account-page">
    <div class="account-card">
        <p class="account-eyebrow">@Localizer["AppName"]</p>
        <h1>@Localizer["AccountRegisterTitle"]</h1>
        <p>@Localizer["AccountRegisterIntro"]</p>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="account-status account-status-error">
                <div>@Localizer["AccountRegistrationFailed"]</div>
                @if (RegistrationErrors.Count > 0)
                {
                    <ul>
                        @foreach (var registrationError in RegistrationErrors)
                        {
                            <li>@registrationError</li>
                        }
                    </ul>
                }
            </div>
        }

        <form method="post" action="/account/register/submit" class="account-form">
            <label>
                <span>@Localizer["AccountFirstName"]</span>
                <input class="form-control" type="text" name="firstName" autocomplete="given-name" required />
            </label>
            <label>
                <span>@Localizer["AccountLastName"]</span>
                <input class="form-control" type="text" name="lastName" autocomplete="family-name" required />
            </label>
            <label>
                <span>@Localizer["AccountEmail"]</span>
                <input class="form-control" type="email" name="email" autocomplete="email" required />
            </label>
            <label>
                <span>@Localizer["AccountSchool"]</span>
                <input class="form-control" type="text" name="school" required placeholder="@Localizer["AccountSchoolPlaceholder"]" />
            </label>
            <label>
                <span>@Localizer["AccountClassName"]</span>
                <input class="form-control" type="text" name="className" required placeholder="@Localizer["AccountClassNamePlaceholder"]" />
            </label>
            <label>
                <span>@Localizer["AccountPassword"]</span>
                <input class="form-control" type="password" name="password" autocomplete="new-password" required />
            </label>
            <label>
                <span>@Localizer["AccountConfirmPassword"]</span>
                <input class="form-control" type="password" name="confirmPassword" autocomplete="new-password" required />
            </label>
            <button class="btn btn-primary" type="submit">@Localizer["AccountRegisterAction"]</button>
        </form>

        <div class="account-links">
            <a href="/account/login">@Localizer["AccountAlreadyRegistered"]</a>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "errors")]
    private string? EncodedErrors { get; set; }

    private IReadOnlyList<string> RegistrationErrors => DecodeErrors(EncodedErrors);

    private static IReadOnlyList<string> DecodeErrors(string? encodedErrors)
    {
        if (string.IsNullOrWhiteSpace(encodedErrors))
        {
            return [];
        }

        try
        {
            var json = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(encodedErrors));
            var errors = JsonSerializer.Deserialize<List<string>>(json);
            return errors?.Where(static error => !string.IsNullOrWhiteSpace(error)).ToArray() ?? [];
        }
        catch
        {
            return [];
        }
    }
}
