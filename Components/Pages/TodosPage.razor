@page "/todos"
@attribute [Authorize(Policy = "ConfirmedEmail")]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["TodoPageTitle"]</PageTitle>

@if (ViewModel is null)
{
    <div class="todos-page-loading">@Localizer["TodoLoading"]</div>
}
else
{
    <div class="todos-page">
        <header class="todos-page-header">
            <div>
                <p>@Localizer["TodoEyebrow"]</p>
                <h1>@Localizer["TodoPageTitle"]</h1>
                <span>@Localizer["TodoPageIntro"]</span>
            </div>
        </header>

        <section class="todos-grid">
            <section class="todo-create-card" aria-labelledby="todo-create-title">
                <EditForm Model="TodoForm" FormName="todo-create-form" OnValidSubmit="HandleCreateAsync" class="todo-create-form">
                    <DataAnnotationsValidator />
                    <div class="todo-create-heading">
                        <span class="todo-create-icon" aria-hidden="true">+</span>
                        <h2 id="todo-create-title">@Localizer["TodoCreateTitle"]</h2>
                    </div>

                    <div class="todo-field">
                        <label for="todo-title">@Localizer["TodoTitle"]</label>
                        <InputText id="todo-title" class="form-control" @bind-Value="TodoForm.Title" />
                        <ValidationMessage For="() => TodoForm.Title" />
                    </div>

                    <div class="todo-field">
                        <label for="todo-description">@Localizer["TodoDescription"]</label>
                        <InputTextArea id="todo-description" class="form-control" rows="5" @bind-Value="TodoForm.Description" />
                        <ValidationMessage For="() => TodoForm.Description" />
                    </div>

                    <div class="todo-field">
                        <label for="todo-due-date">@Localizer["TodoDueDate"]</label>
                        <InputDate id="todo-due-date" class="form-control" @bind-Value="TodoForm.DueDate" />
                    </div>

                    <button class="btn btn-primary todo-add-button" type="submit">
                        <span>@Localizer["TodoAdd"]</span>
                        <span aria-hidden="true">+</span>
                    </button>
                </EditForm>
            </section>

            <TodoList
                TitleKey="TodoOpenTitle"
                EmptyTextKey="TodoNoOpen"
                Items="ViewModel.OpenTodos"
                ShowCompleteAction="true"
                Complete="HandleCompleteAsync"
                Delete="HandleDeleteAsync" />

            <TodoList
                TitleKey="TodoCompletedTitle"
                EmptyTextKey="TodoNoCompleted"
                Items="ViewModel.CompletedTodos"
                Delete="HandleDeleteAsync" />
        </section>
    </div>
}
