@page "/weekly-reports/grid"
@attribute [Authorize(Policy = "ConfirmedEmail")]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["WeeklyOverviewGridPageTitle"]</PageTitle>

@if (Overview is null)
{
    <div class="weekly-grid-loading">@Localizer["WeeklyOverviewLoading"]</div>
}
else
{
    <div class="weekly-grid-page">
        <header class="weekly-grid-header">
            <div>
                <h1>@Localizer["WeeklyOverviewGridPageTitle"]</h1>
                <span>@Localizer["WeeklyOverviewPageIntro"]</span>
            </div>
        </header>

        <div class="weekly-grid-actions">
            <section class="weekly-grid-navigation" aria-label="@Localizer["WeeklyOverviewNavigation"]">
                <button class="weekly-grid-today-button" type="button" @onclick="GoToToday">@Localizer["WeeklyOverviewCurrentWeek"]</button>
                <button class="weekly-grid-nav-button" type="button" title="@Localizer["WeeklyOverviewPreviousWeek"]" aria-label="@Localizer["WeeklyOverviewPreviousWeek"]" @onclick="GoToPreviousWeek">
                    &lt;
                </button>
                <label class="weekly-grid-date-picker">
                    <span class="visually-hidden">@Localizer["WeeklyOverviewJumpToWeek"]</span>
                    <input class="form-control" type="date" value="@SelectedDateString" @onchange="HandleDateChangedAsync" />
                </label>
                <button class="weekly-grid-nav-button" type="button" title="@Localizer["WeeklyOverviewNextWeek"]" aria-label="@Localizer["WeeklyOverviewNextWeek"]" @onclick="GoToNextWeek">
                    &gt;
                </button>
            </section>
            <div class="weekly-grid-action-tools">
                <div class="weekly-grid-view-switch" aria-label="Ansicht wechseln">
                    <span class="weekly-grid-view-label">Ansicht</span>
                    <div class="weekly-grid-view-options" role="group" aria-label="Ansicht">
                        <a class="weekly-grid-view-option active" href="@GridViewHref" aria-current="page">
                            <span class="weekly-grid-view-icon weekly-grid-view-icon-grid" aria-hidden="true"></span>
                            Raster
                        </a>
                        <a class="weekly-grid-view-option" href="@ListViewHref">
                            <span class="weekly-grid-view-icon weekly-grid-view-icon-list" aria-hidden="true"></span>
                            Liste
                        </a>
                    </div>
                </div>
                <a class="weekly-grid-export-button" href="@ExportHref" download data-enhance-nav="false">@Localizer["DashboardExportPdf"]</a>
            </div>
        </div>

        <section class="weekly-grid-summary">
            <span>@Localizer["WeeklyOverviewTitle"] @Overview.CalendarWeek</span>
            <strong>@Overview.RecordedHours.ToString("0.##") h</strong>
        </section>

        <section class="weekly-grid-days">
            @foreach (var day in Overview.Days)
            {
                <article class="weekly-grid-day">
                    <header class="weekly-grid-day-header">
                        <a href="@($"report-entries/new?date={day.Date:yyyy-MM-dd}")">
                            <span>@Localizer[day.DayKey]</span>
                            <strong>@day.Date.ToString("dd.MM.yyyy")</strong>
                        </a>
                    </header>

                    <div class="weekly-grid-day-content">
                        @if (day.Entries.Count == 0)
                        {
                            <p class="weekly-grid-empty">@Localizer["WeeklyOverviewNoEntries"]</p>
                        }
                        else
                        {
                            <div class="weekly-grid-entry-list">
                                @foreach (var entry in day.Entries)
                                {
                                    <a class="weekly-grid-entry" href="@($"report-entries/{entry.Id}")">
                                        <strong>@entry.Title</strong>
                                    </a>
                                }
                            </div>
                        }
                    </div>

                    <footer class="weekly-grid-day-footer" aria-label="@Localizer["WeeklyOverviewRecorded"]">
                        <strong>@day.TotalHours.ToString("0.##") h</strong>
                    </footer>
                </article>
            }
        </section>
    </div>
}
