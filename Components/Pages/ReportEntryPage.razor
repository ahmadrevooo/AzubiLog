@page "/report-entries/new"
@page "/report-entries/{EntryId:int}"
@attribute [Authorize(Policy = "ConfirmedEmail")]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["ReportEntryPageTitle"]</PageTitle>

@if (ViewModel is null)
{
    <div class="report-entry-loading">@Localizer["ReportEntryLoading"]</div>
}
else
{
    <div class="report-entry-page">
        <section class="report-entry-main">
            <div class="report-entry-workspace @(ViewModel.SchoolDaySuggestion?.IsSchoolDay == true ? "has-school-hint" : string.Empty)">
                @if (ViewModel.SchoolDaySuggestion?.IsSchoolDay == true)
                {
                    <aside class="report-entry-school-hint">
                        <span>@Localizer["ReportEntrySchoolDayHint"]</span>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="HandleApplySchoolDayAsync">
                            @Localizer["ReportEntryApplySchoolDay"]
                        </button>
                    </aside>
                }

                <ReportEntryForm
                    Model="ViewModel.Entry"
                    Categories="ViewModel.Categories"
                    Trainers="ViewModel.Trainers"
                    CalculatedHours="ViewModel.CalculatedHours"
                    RestoredDraft="ViewModel.RestoredDraft"
                    OnFieldChanged="HandleFieldChangedAsync"
                    OnDateChanged="HandleDateChangedAsync"
                    OnCreateCategory="HandleCreateCategoryAsync"
                    OnDraft="HandleDraftAsync"
                    OnSave="HandleSaveAsync"
                    OnDelete="HandleDeleteAsync" />
            </div>

            <DailySummaryPanel
                Summary="ViewModel.DailySummary"
                DailyReportEmailHref="@ViewModel.DailyReportEmailHref" />
        </section>
    </div>
}
