@page "/"
@attribute [Authorize(Policy = "ConfirmedEmail")]
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["DashboardPageTitle"]</PageTitle>

@if (ViewModel is null)
{
    <div class="dashboard-loading">@Localizer["DashboardLoading"]</div>
}
else
{
    <div class="dashboard-page">
        <section class="dashboard-greeting" aria-labelledby="dashboard-heading">
            <div class="dashboard-greeting-copy">
                <p class="dashboard-eyebrow">Kalenderwoche @ViewModel.CalendarWeek</p>
                <h1 id="dashboard-heading">@GetWelcomeHeading()</h1>
                <p>Deine Übersicht für die aktuelle Ausbildungswoche.</p>
            </div>

            <aside class="today-card" aria-label="Heute">
                <span class="icon-box icon-box-green" aria-hidden="true">
                    <span class="bi bi-calendar3"></span>
                </span>
                <div>
                    <span>Heute</span>
                    <strong>@TodayLabel</strong>
                </div>
            </aside>
        </section>

        <section class="dashboard-layout" aria-label="Dashboard Übersicht">
            <div class="dashboard-left-column">
                <section class="dashboard-card todo-action-card" aria-labelledby="todo-action-title">
                    <div class="card-heading todo-card-heading">
                        <div class="icon-box icon-box-green" aria-hidden="true">
                            <span class="bi bi-list-check"></span>
                        </div>
                        <div class="todo-heading-copy">
                            <h2 id="todo-action-title">To-dos</h2>
                            <p>Deine offenen Aufgaben</p>
                        </div>
                        <a class="btn btn-primary todo-action-button" href="/todos">Neue Aufgabe erstellen</a>
                    </div>

                    <div class="todo-overview">
                        <h3>Offene Aufgaben</h3>

                        @if (OpenTodos.Count == 0)
                        {
                            <p class="todo-empty-state">Keine offenen Aufgaben</p>
                        }
                        else
                        {
                            <div class="todo-list" aria-label="Offene To-dos">
                                @foreach (var todo in OpenTodos)
                                {
                                    <div class="todo-list-item">
                                        <span class="todo-status-dot" aria-hidden="true"></span>
                                        <span class="todo-item-title">@todo.Title</span>
                                        <span class="todo-item-date">@GetTodoDueDateLabel(todo.DueDate)</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <a class="todo-all-link" href="/todos">
                        <span>Alle Aufgaben anzeigen</span>
                        <span aria-hidden="true">&gt;</span>
                    </a>
                </section>

                <section class="dashboard-card timer-card" aria-labelledby="timer-title">
                    <div class="card-heading">
                        <span class="icon-box icon-box-blue" aria-hidden="true">
                            <span class="bi bi-clock-history"></span>
                        </span>
                        <div>
                            <h2 id="timer-title">Timer</h2>
                            <p>Dauer wählen</p>
                        </div>
                    </div>

                    <div class="timer-options" role="group" aria-label="Dauer wählen">
                        @foreach (var duration in TimerDurations)
                        {
                            <button class="@(duration.Label == SelectedTimerLabel ? "active" : null)" type="button" disabled="@isTimerRunning" @onclick="() => SelectTimerDuration(duration)">
                                @duration.Label
                            </button>
                        }
                    </div>

                    <label class="custom-duration">
                        <span>Custom</span>
                        <input class="form-control" type="number" min="1" value="@customTimerMinutes" disabled="@isTimerRunning" aria-label="Eigene Dauer in Minuten" @onchange="HandleCustomTimerMinutesChanged" />
                        <small>Minuten</small>
                    </label>

                    <div class="timer-display" aria-live="polite">@TimerDisplay</div>

                    <div class="timer-actions">
                        <button class="btn btn-primary" type="button" disabled="@(!CanStartTimer)" @onclick="StartTimerAsync">Start</button>
                        <button class="btn btn-outline-secondary" type="button" disabled="@(!isTimerRunning)" @onclick="PauseTimer">Pause</button>
                        <button class="btn btn-outline-secondary" type="button" @onclick="ResetTimer">Reset</button>
                    </div>
                </section>
            </div>

            <section class="dashboard-card progress-card" aria-labelledby="progress-title">
                <div class="progress-content">
                    <div class="month-progress" aria-labelledby="progress-title">
                        <div class="section-heading">
                            <div>
                                <h3 id="progress-title">Kalender - @DisplayedMonthLabel</h3>
                                <p>Markiere deine Tage nach Arbeit, Schule, Urlaub, Krankheit oder Prüfung.</p>
                            </div>
                            <div class="calendar-nav" aria-label="Monatsnavigation">
                                <label class="month-picker">
                                    <span class="visually-hidden">Monat auswählen</span>
                                    <input type="month" value="@DisplayedMonthValue" @onchange="HandleDisplayedMonthChangedAsync" />
                                </label>
                                <button class="current-month-button" type="button" @onclick="ShowCurrentMonthAsync">Diesen Monat</button>
                                <button class="month-step-button" type="button" aria-label="Vorheriger Monat" @onclick="ShowPreviousMonthAsync">
                                    <span class="bi bi-chevron-left" aria-hidden="true"></span>
                                </button>
                                <button class="month-step-button" type="button" aria-label="Nächster Monat" @onclick="ShowNextMonthAsync">
                                    <span class="bi bi-chevron-right" aria-hidden="true"></span>
                                </button>
                            </div>
                        </div>

                        <div class="calendar-grid progress-weekdays" aria-hidden="true">
                            @foreach (var dayName in WeekdayLabels)
                            {
                                <span>@dayName</span>
                            }
                        </div>

                        <div class="calendar-grid progress-grid">
                            @foreach (var day in ProgressDays)
                            {
                                <div class="progress-day-cell">
                                    <button class="@GetProgressDayClass(day)" type="button" aria-label="@GetProgressDayLabel(day)" @onclick="() => ToggleMarkerMenu(day)">
                                        @day.Date.Day
                                    </button>

                                    @if (SelectedMarkerDate == DateOnly.FromDateTime(day.Date))
                                    {
                                        <div class="marker-menu" role="menu">
                                            <button type="button" role="menuitem" @onclick="() => SetMarkerAsync(CalendarDayType.Workday)">
                                                <span class="marker-color marker-color-workday" aria-hidden="true"></span>
                                                <span>Arbeitstag</span>
                                            </button>
                                            <button type="button" role="menuitem" @onclick="() => SetMarkerAsync(CalendarDayType.SchoolDay)">
                                                <span class="marker-color marker-color-school-day" aria-hidden="true"></span>
                                                <span>Schultag</span>
                                            </button>
                                            <button type="button" role="menuitem" @onclick="() => SetMarkerAsync(CalendarDayType.Vacation)">
                                                <span class="marker-color marker-color-vacation" aria-hidden="true"></span>
                                                <span>Urlaub</span>
                                            </button>
                                            <button type="button" role="menuitem" @onclick="() => SetMarkerAsync(CalendarDayType.SickLeave)">
                                                <span class="marker-color marker-color-sick-leave" aria-hidden="true"></span>
                                                <span>Krankheit</span>
                                            </button>
                                            <button type="button" role="menuitem" @onclick="() => SetMarkerAsync(CalendarDayType.Exam)">
                                                <span class="marker-color marker-color-exam" aria-hidden="true"></span>
                                                <span>Prüfung / Klausur</span>
                                            </button>
                                            <button class="marker-menu-remove" type="button" role="menuitem" @onclick="RemoveMarkerAsync">Markierung entfernen</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="week-progress-footer">
                            <div class="marker-legend" aria-label="Legende der Tagesmarkierungen">
                                <span>
                                    <span class="marker-color marker-color-workday" aria-hidden="true"></span>
                                    Arbeitstag
                                </span>
                                <span>
                                    <span class="marker-color marker-color-school-day" aria-hidden="true"></span>
                                    Schultag
                                </span>
                                <span>
                                    <span class="marker-color marker-color-vacation" aria-hidden="true"></span>
                                    Urlaub
                                </span>
                                <span>
                                    <span class="marker-color marker-color-sick-leave" aria-hidden="true"></span>
                                    Krankheit
                                </span>
                                <span>
                                    <span class="marker-color marker-color-exam" aria-hidden="true"></span>
                                    Prüfung/Klausur
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </section>
    </div>
}
