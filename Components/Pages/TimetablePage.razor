@page "/timetable"
@attribute [Authorize(Policy = "ConfirmedEmail")]
@inject IStringLocalizer<SharedResource> Localizer
@inject ITimetableService TimetableService
@inject ICurrentUserService CurrentUserService
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>@Localizer["TimetableManagementTitle"]</PageTitle>

@if (CurrentUser is null)
{
    <div class="profile-loading">Laden...</div>
}
else
{
    <div class="profile-page">
        <header class="profile-page-header">
            <p>@Localizer["TimetableNavItem"]</p>
            <h1>@Localizer["TimetableManagementTitle"]</h1>
            <span>Verwalte deinen Wochenstundenplan. Trage deine Fächer, Lehrer und Räume ein.</span>
        </header>

        @if (!string.IsNullOrWhiteSpace(StatusMessage))
        {
            <div class="profile-status">@StatusMessage</div>
        }

        <section class="profile-card">
            <div class="profile-card-header">
                <div>
                    <p>Wochenübersicht</p>
                    <h2>Dein Stundenplan</h2>
                </div>
                <div class="timetable-header-badge">
                    <strong>@FilledDayCount / @DayEntries.Count</strong>
                    <span>Tage gepflegt</span>
                </div>
            </div>

            <div class="timetable-day-tabs">
                @foreach (var dayEntry in DayEntries)
                {
                    <button type="button"
                            class="timetable-tab @(dayEntry.DayOfWeek == SelectedDay ? "is-active" : "") @(dayEntry.SubjectRows.Count > 0 ? "has-entries" : "")"
                            @onclick="() => SelectDay(dayEntry.DayOfWeek)">
                        <span class="timetable-tab-short">@GetDayShort(dayEntry.DayOfWeek)</span>
                        <span class="timetable-tab-full">@GetDayName(dayEntry.DayOfWeek)</span>
                        @if (dayEntry.SubjectRows.Count > 0)
                        {
                            <span class="timetable-tab-count">@dayEntry.SubjectRows.Count</span>
                        }
                    </button>
                }
            </div>

            @{ var activeDay = DayEntries.FirstOrDefault(d => d.DayOfWeek == SelectedDay); }
            @if (activeDay is not null)
            {
                <div class="timetable-day-content">
                    <div class="timetable-day-content-header">
                        <h3>@GetDayName(activeDay.DayOfWeek)</h3>
                        <span class="timetable-entry-count">
                            @(activeDay.SubjectRows.Count == 0 ? "Keine Einträge" : $"{activeDay.SubjectRows.Count} Einträge")
                        </span>
                    </div>

                    @if (activeDay.SubjectRows.Count > 0)
                    {
                        <div class="timetable-subject-list">
                            @for (var i = 0; i < activeDay.SubjectRows.Count; i++)
                            {
                                var row = activeDay.SubjectRows[i];
                                var index = i + 1;
                                <div class="timetable-subject-item">
                                    <span class="timetable-subject-index">@index</span>
                                    <div class="timetable-subject-fields">
                                        <InputText class="form-control"
                                                   @bind-Value="row.Fach"
                                                   placeholder="Fach (z.B. Mathe)" />
                                        <InputText class="form-control"
                                                   @bind-Value="row.Lehrer"
                                                   placeholder="Lehrer (z.B. Hr. Müller)" />
                                        <InputText class="form-control"
                                                   @bind-Value="row.Raum"
                                                   placeholder="Raum (optional)" />
                                    </div>
                                    <button type="button"
                                            class="btn btn-icon-danger"
                                            title="Entfernen"
                                            @onclick="() => RemoveSubjectRow(activeDay.DayOfWeek, row)">
                                        &times;
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="timetable-empty-state">
                            <span>Noch keine Einträge für @GetDayName(activeDay.DayOfWeek).</span>
                            <span>Klicke auf "Stunde hinzufügen" um loszulegen.</span>
                        </div>
                    }

                    <button type="button"
                            class="btn btn-outline-primary timetable-add-btn"
                            @onclick="() => AddSubjectRow(activeDay.DayOfWeek)">
                        + Stunde hinzufügen
                    </button>
                </div>
            }

            <div class="timetable-actions">
                <button class="btn btn-primary" @onclick="SaveTimetableAsync" disabled="@IsSaving">
                    @(IsSaving ? "Wird gespeichert..." : "Stundenplan speichern")
                </button>
            </div>
        </section>

        <section class="profile-card">
            <div class="profile-card-header">
                <div>
                    <p>Ausfälle</p>
                    <h2>Unterrichtsausfälle</h2>
                </div>
                <div class="timetable-header-badge">
                    <strong>@Cancellations.Count</strong>
                    <span>Eingetragen</span>
                </div>
            </div>

            <div class="timetable-cancellation-form">
                <div class="profile-grid">
                    <label>
                        <span>Tag</span>
                        <select class="form-control" @bind="SelectedCancellationDay">
                            @foreach (var dayEntry in DayEntries.Where(d => d.SubjectRows.Count > 0))
                            {
                                <option value="@((int)dayEntry.DayOfWeek)">@GetDayName(dayEntry.DayOfWeek)</option>
                            }
                        </select>
                    </label>
                    <label>
                        <span>Datum</span>
                        <input class="form-control" type="date" @bind="CancellationDate" />
                    </label>
                    <label>
                        <span>Grund (optional)</span>
                        <input class="form-control" type="text" @bind="CancellationReason" placeholder="z.B. Lehrer krank" />
                    </label>
                </div>
                <button class="btn btn-secondary" @onclick="AddCancellationAsync" disabled="@IsSaving">
                    Ausfall eintragen
                </button>
            </div>

            @if (Cancellations.Count > 0)
            {
                <div class="timetable-cancellation-list">
                    @foreach (var cancellation in Cancellations)
                    {
                        <div class="timetable-cancellation-item">
                            <div class="timetable-cancellation-info">
                                <strong>@GetDayName(cancellation.ClassTimetableEntry.DayOfWeek)</strong>
                                <span>@cancellation.Date.ToString("dd.MM.yyyy")</span>
                                @if (!string.IsNullOrWhiteSpace(cancellation.Reason))
                                {
                                    <em>@cancellation.Reason</em>
                                }
                            </div>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCancellationAsync(cancellation.Id)">
                                Entfernen
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="timetable-empty-state">
                    <span>Keine Ausfälle eingetragen.</span>
                </div>
            }
        </section>
    </div>
}
